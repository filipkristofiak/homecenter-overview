services:
  prometheus:
    image: prom/prometheus:{{ prometheus_image_tag }}
    container_name: prometheus
    restart: unless-stopped
    ports:
      - "{{ prometheus_port }}:9090"
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - ./alerts.yml:/etc/prometheus/alerts.yml:ro
      - prometheus_data:/prometheus
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --storage.tsdb.path=/prometheus
      - --storage.tsdb.retention.time={{ prometheus_retention }}
      - --web.enable-lifecycle

  pve-exporter:
    image: prompve/prometheus-pve-exporter:{{ pve_exporter_image_tag }}
    container_name: pve-exporter
    restart: unless-stopped
    ports:
      - "{{ pve_exporter_port }}:9221"
    volumes:
      - ./pve-exporter.yml:/etc/prometheus/pve.yml:ro

  grafana:
    image: grafana/grafana:{{ grafana_image_tag }}
    container_name: grafana
    restart: unless-stopped
    ports:
      - "{{ grafana_port }}:3000"
    volumes:
      - grafana_data:/var/lib/grafana
    environment:
      - GF_SECURITY_ADMIN_PASSWORD={{ grafana_admin_password }}
    depends_on:
      - prometheus

  status-page:
    image: nginx:{{ nginx_image_tag }}
    container_name: status-page
    restart: unless-stopped
    ports:
      - "{{ status_page_port }}:80"
    volumes:
      - ./status-nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./status:/usr/share/nginx/html/status:ro

volumes:
  prometheus_data:
  grafana_data:
